# Copy to .env and edit. Loaded automatically by the CLI.

# OpenAI-compatible endpoint of your local VLM server.
# vLLM default:       http://localhost:8000/v1
# llama.cpp default:  http://localhost:8080/v1
# SGLang default:     http://localhost:30000/v1
LLM_BASE_URL=http://localhost:8000/v1

# Model identifier as known to the server.
LLM_MODEL=Qwen/Qwen3-VL-8B-Instruct

# Any non-empty string works for local servers; real key for hosted endpoints.
LLM_API_KEY=sk-local
